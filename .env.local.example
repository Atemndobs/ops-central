# Convex (same deployment as cleaners app)
NEXT_PUBLIC_CONVEX_URL=https://usable-anaconda-394.eu-west-1.convex.cloud
CONVEX_DEPLOYMENT=dev:usable-anaconda-394

# Clerk (same as cleaners app)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
CLERK_WEBHOOK_SIGNING_SECRET=whsec_...
CLERK_WEBHOOK_SYNC_TOKEN=replace_with_long_random_token
CLERK_BACKFILL_TOKEN=optional_manual_backfill_token

# WhatsApp (Meta Cloud API)
WHATSAPP_ACCESS_TOKEN=your_meta_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_random_verify_token
WHATSAPP_APP_SECRET=your_meta_app_secret
WHATSAPP_GRAPH_API_VERSION=v23.0
WHATSAPP_BUSINESS_PHONE_E164=+15551234567

# Dev test-login presets for the custom sign-in page.
# Hidden in production by default unless NEXT_PUBLIC_ENABLE_TEST_LOGIN_PRESETS=true.
NEXT_PUBLIC_ENABLE_TEST_LOGIN_PRESETS=true
EXPO_PUBLIC_TEST_CLEANER_EMAIL=cleaner@test.com
EXPO_PUBLIC_TEST_MANAGER_EMAIL=manager@test.com
EXPO_PUBLIC_TEST_PROPERTY_OPS_EMAIL=ops@test.com
EXPO_PUBLIC_TEST_ADMIN_EMAIL=admin@test.com
EXPO_PUBLIC_TEST_PASSWORD=replace_with_shared_test_password

# Web Push (browser PWA notifications)
NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY=replace_with_vapid_public_key
WEB_PUSH_VAPID_PUBLIC_KEY=replace_with_same_vapid_public_key
WEB_PUSH_VAPID_PRIVATE_KEY=replace_with_vapid_private_key
WEB_PUSH_VAPID_SUBJECT=mailto:ops@example.com

# Cloudinary (for property photos)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset

# Backblaze B2 (hot photo storage, S3-compatible)
B2_BUCKET=job-photos
B2_ARCHIVE_BUCKET=job-photos-archive
B2_REGION=us-east-005
B2_S3_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_KEY_ID=your-b2-key-id
B2_APPLICATION_KEY=your-b2-application-key
B2_UPLOAD_URL_TTL_SECONDS=900
B2_READ_URL_TTL_SECONDS=3600

# MinIO (7-day archive backup)
MINIO_BUCKET=photo-archive
MINIO_REGION=us-east-1
MINIO_ENDPOINT=minio.example.internal:9000
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_UPLOAD_URL_TTL_SECONDS=900
MINIO_READ_URL_TTL_SECONDS=3600

# PostHog analytics (optional — analytics no-ops when unset)
# Values from PostHog project settings. Matches the naming used in the
# archived jna-bs-admin app so existing keys port over.
NEXT_PUBLIC_POSTHOG_API_KEY=phc_your_key_here
NEXT_PUBLIC_POSTHOG_API_HOST=https://us.i.posthog.com
